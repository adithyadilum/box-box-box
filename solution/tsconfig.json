{
  "compilerOptions": {
    // Environment Settings
    "module": "CommonJS",
    "target": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    // Specifically telling TypeScript to include Node types
    "types": [
      "node"
    ],
    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "skipLibCheck": true
  }
}